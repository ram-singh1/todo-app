# Copy this file to .env locally. Set the same vars in Render's dashboard for prod.
# Never commit your real .env — it's gitignored on purpose.

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string. From Atlas: Cluster → Connect → Drivers.
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://root:examplepassword@localhost:27017/ai-todo-diary?authSource=admin

# JWT
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=30d

# Encryption key for at-rest fields (must be exactly 32 chars).
ENCRYPTION_KEY=replace_with_a_32_character_secret

# Cloudinary — only required in production where local disk is ephemeral.
# Get these from cloudinary.com → Dashboard → Account Details.
# When all three are set, uploads route uses Cloudinary; otherwise falls back to
# local disk (fine for development).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS allowlist. Comma-separated origins, or leave blank to allow all
# (acceptable for a public mobile API since auth is JWT-based).
# Example: https://example.com,https://app.example.com
CORS_ORIGINS=

# Optional: OpenAI for AI features (currently unused).
OPENAI_API_KEY=
